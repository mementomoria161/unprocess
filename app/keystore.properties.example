# Copy this file to `keystore.properties` (same directory) and fill in the
# values for your own release keystore. The release build will then be signed
# with it — see app/build.gradle for the wiring.
#
# Generate a fresh release keystore with:
#   keytool -genkey -v -keystore unprocess-release.jks -keyalg RSA \
#           -keysize 2048 -validity 10000 -alias unprocess
#
# Keep this file and the .jks OUT of version control (already gitignored).

storeFile=unprocess-release.jks
storePassword=CHANGE_ME
keyAlias=unprocess
keyPassword=CHANGE_ME
