<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/view_finder_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:clipToOutline="true"
        app:layout_constrainedWidth="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/capture_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <com.mementomoria.unprocess.utils.AutoFitSurfaceView
            android:id="@+id/view_finder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <!-- Shutter-flash overlay (briefly opaque black at the moment of exposure). -->
        <View
            android:id="@+id/overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <!-- Capture overlay. Two states:
             - SAVING: just a semi-transparent dim over the live preview
               (no spinner, no text — minimal visual noise).
             - DONE: same dim PLUS the just-saved photo shown fitCenter at
               the preview's full size. Dismissed by the capture button,
               whose text switches to "Take new" while this overlay is in
               its DONE state. Clickable=true so taps on the preview area
               can't reach the underlying surface while we're showing it. -->
        <FrameLayout
            android:id="@+id/capture_progress_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <VideoView
                android:id="@+id/capture_progress_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/capture_progress_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/progress_thumbnail_desc"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/capture_progress_play_button"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_play"
                app:tint="@android:color/black"
                app:backgroundTint="?attr/colorPrimary"
                app:fabCustomSize="72dp"
                app:maxImageSize="36dp"
                android:visibility="gone"
                android:contentDescription="Play preview video" />

        </FrameLayout>

        <!-- Super8 "film reel" countdown. Shown only while a Super8 clip is
             being recorded; the reel is artificially limited to 200 s. -->
        <LinearLayout
            android:id="@+id/film_reel_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/film_reel_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/preset_super8"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/film_reel_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="1000"
                android:progress="1000"
                android:progressTint="?attr/colorPrimary"
                android:progressBackgroundTint="#55FFFFFF" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/lens_selector_card"
        android:layout_width="0dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
        app:contentPadding="0dp"
        app:strokeWidth="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:clipToOutline="false"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/view_finder_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.mementomoria.unprocess.views.LensSelectorView
            android:id="@+id/lens_selector"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/film_mode_container"
        android:layout_width="104dp"
        android:layout_height="104dp"
        android:layout_marginBottom="48dp"
        android:layout_marginStart="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/film_mode_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/film_mode"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="?attr/colorSecondaryContainer"
            app:cornerRadius="52dp"
            app:icon="@drawable/ic_camera_roll"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="30dp"
            app:iconTint="?attr/colorOnSecondaryContainer"
            android:visibility="gone" />

        <com.mementomoria.unprocess.views.FilmModeDialView
            android:id="@+id/inline_film_mode_dial"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <com.mementomoria.unprocess.views.CaptureDevelopProgressView
        android:id="@+id/capture_develop_progress"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:clickable="false"
        android:importantForAccessibility="no"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/capture_button"
        app:layout_constraintEnd_toEndOf="@id/capture_button"
        app:layout_constraintStart_toStartOf="@id/capture_button" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/capture_button"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:layout_marginBottom="48dp"
        android:layout_marginEnd="32dp"
        android:layout_marginStart="8dp"
        android:contentDescription="@string/capture"
        android:gravity="center"
        android:maxLines="1"
        android:text=""
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="52dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/film_mode_container" />

    <!-- Dark semi-transparent dim overlay when settings menu is active -->
    <View
        android:id="@+id/settings_dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- Settings menu anchored inside the viewfinder's lower-right corner. -->
    <LinearLayout
        android:id="@+id/settings_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/settings_toggle"
        app:layout_constraintEnd_toEndOf="@+id/settings_toggle">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mode_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="JPEG"
            android:textSize="16sp"
            android:maxLines="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="64dp"
            android:paddingEnd="64dp"
            app:icon="@drawable/ic_save"
            app:iconPadding="8dp"
            app:iconSize="24dp"
            app:iconGravity="start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/framerate_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="30 FPS"
            android:textSize="16sp"
            android:maxLines="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone"
            android:paddingStart="64dp"
            android:paddingEnd="64dp"
            app:icon="@drawable/ic_art_track"
            app:iconPadding="8dp"
            app:iconSize="24dp"
            app:iconGravity="start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/resolution_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="1080p"
            android:textSize="16sp"
            android:maxLines="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone"
            android:paddingStart="64dp"
            android:paddingEnd="64dp"
            app:icon="@drawable/ic_mp"
            app:iconPadding="8dp"
            app:iconSize="24dp"
            app:iconGravity="start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aspect_ratio_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="@string/aspect_ratio_full"
            android:textSize="16sp"
            android:maxLines="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="64dp"
            android:paddingEnd="64dp"
            app:icon="@drawable/ic_aspect_ratio_new"
            app:iconPadding="8dp"
            app:iconSize="24dp"
            app:iconGravity="start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/flash_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="Flash Off"
            android:textSize="16sp"
            android:maxLines="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="64dp"
            android:paddingEnd="64dp"
            app:icon="@drawable/ic_flash_off_new"
            app:iconPadding="8dp"
            app:iconSize="24dp"
            app:iconGravity="start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/gallery_button"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="View Gallery"
            android:textSize="16sp"
            android:maxLines="1"
            android:contentDescription="@string/gallery"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="64dp"
            android:paddingEnd="64dp"
            app:icon="@drawable/ic_gallery"
            app:iconPadding="8dp"
            app:iconSize="24dp"
            app:iconGravity="start" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mode_selection_pill"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_gravity="end"
            app:cardBackgroundColor="?attr/colorSecondaryContainer"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:clipToOutline="true"
            app:contentPadding="0dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:id="@+id/mode_selection_segment_track"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/camera_toggle"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:minWidth="56dp"
                    android:minHeight="0dp"
                    app:icon="@drawable/ic_photo_camera"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconSize="24dp"
                    app:cornerRadius="28dp"
                    app:strokeWidth="0dp"
                    app:backgroundTint="@android:color/transparent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/video_toggle"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:minWidth="56dp"
                    android:minHeight="0dp"
                    app:icon="@drawable/ic_videocam"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconSize="24dp"
                    app:cornerRadius="28dp"
                    app:strokeWidth="0dp"
                    app:backgroundTint="@android:color/transparent" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Above the dim overlay; hidden while the lens selector is expanded. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/settings_toggle"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        app:icon="@drawable/ic_settings_new"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:layout_constraintBottom_toBottomOf="@+id/view_finder_container"
        app:layout_constraintEnd_toEndOf="@+id/view_finder_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
